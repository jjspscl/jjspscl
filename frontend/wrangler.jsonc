{
  "name": "jjspscl",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "routes": [
    { "pattern": "jjspscl.com", "custom_domain": true }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jjspscl",
      "database_id": "e502a5c2-f63e-40ae-b8b7-9ed12458838d"
    }
  ]
}
