---
import { TRANSITION_NAMES } from "@lib/constants/transition";

interface Props {
    class?: string;
    width?: string;
    height?: string;
}

const { class: className = "", width = "40", height = "40" } = Astro.props;
---

<img
    src="/me.png"
    alt="Joshua"
    class:list={["rounded-lg", className]}
    width={width}
    height={height}
    transition:name={TRANSITION_NAMES.MY_IMAGE}
/>
