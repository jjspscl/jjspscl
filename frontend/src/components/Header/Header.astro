---
import { links } from "@lib/constants/links";

import HeaderLink from "./HeaderLink.astro";
import Logo from "../assets/Logo.astro";

const currentPath = Astro.url.pathname;
const filteredLinks = links.filter(link => link.href !== currentPath);
---

<header
    class="container flex justify-between items-center mx-auto max-w-screen-md px-4 my-5"
>
    <a class="font-bold flex items-center gap-2" href="/">
        <Logo width={36} height={36} />
    </a>
    <nav aria-label="Main navigation" class="flex text-lg md:text-xl my-auto gap-1">
        {
            filteredLinks.map(({ href, text }) => (
                <HeaderLink 
                    href={href} 
                    label={text} 
                />
            ))
        }
    </nav>
</header>
