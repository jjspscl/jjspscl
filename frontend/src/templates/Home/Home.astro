---
import HomeHeader from "./components/HomeHeader.vue";

---
<div class="home-container">
    <HomeHeader client:only/>
    <slot/>
</div>

<style lang="scss">
@import '../../styles/colors.scss';
@import '../../styles/fonts.scss';


:global(.quiapo) {
    font-family: 'Quiapo';
}

:global(.kagitingan) {
    font-family: 'Kagitingan';
}

:global(.maragsa) {
    font-family: 'Maragsa';
    font-size: 10rem;
}

.home-container {
    min-height: 100vh;
    width: 100%;
}

:global(.home-section) {
    min-height: 100vh;
}
.home-section {
    &h1 {
        font-size: 50px;
    }
}

html, body {
  width: 100%;
  overflow-x: hidden;
}

// MOBILE
@media (max-width: 800px) {
}
</style>

