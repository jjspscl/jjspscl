---
import { storyblokEditable, renderRichText } from "@storyblok/astro";

import ArticleTag from "./ArticleTag.astro";

import type { IArticleBlok } from "../blog.type";

interface Props {
  blok: IArticleBlok;
  slug: string;
}
const { blok, slug } = Astro.props;
const renderedRichText = renderRichText(blok.content);
const tags = blok.tags || [];
---

<style is:global>
  .blog-target:target {
    background-color: #aaf;
  }

  @media (prefers-color-scheme: dark) {
    .blog-target:target {
      background-color: #ffa;
      color: #000;
    }
  }

  .prose-override * {
    color: inherit !important;
  }
  
  .prose-override a {
    color: var(--theme-link) !important;
    text-decoration: underline !important;
  }
  
  .prose-override a:hover {
    opacity: 0.8;
  }

  .prose-override code {
    color: var(--color-vhs-red) !important;
  }

  .prose-override pre,
  .prose-override pre * {
    color: #d4d4d4 !important;
  }

  @media (prefers-color-scheme: dark) {
    .prose-override code {
      color: #fbbf24 !important;
    }
  }
</style>

<article {...storyblokEditable(blok)} class="blog-target rounded mb-28 text-text-primary">
    <div class="mb-12">
        <h1
            class="text-4xl md:text-5xl font-bold mt-12 mb-4 leading-tight"
            transition:name={slug}
        >
            {blok.title}
        </h1>
        <p class="text-base text-text-secondary mb-4">
            {blok.created_at}
        </p>
        {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
                {tags.map((tag) => (
                    <ArticleTag 
                        tag={tag.content} 
                        href={`/blog?tags=${encodeURIComponent(tag.content.title)}`}
                        colorful 
                    />
                ))}
            </div>
        )}
        <h2 class="text-xl md:text-2xl font-semibold mb-6">
            {blok.subtitle}
        </h2>
        <div
            class="prose-override prose prose-base md:prose-lg max-w-none dark:prose-invert prose-headings:font-bold prose-headings:mb-2 prose-p:leading-relaxed prose-pre:bg-[#1e1e1e] prose-code:text-sm"
            set:html={renderedRichText}
        />
    </div>
</article>
